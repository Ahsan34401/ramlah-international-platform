# Hostinger → Environment variables → har line ko KEY / VALUE ki tarah add karo.
# AUTH_SECRET ki length kam az kam 16 chars honi chahiye (behtar: 40+ random).
# SMTP khali chhor sakte ho — mail tab tak skip rahegi jab tak SMTP_HOST na ho.

# Relative (app cwd se resolve — zyada tar kaafi hai):
DATABASE_URL=file:./prisma/prod.db
# Agar SQLite error 14 runtime par aaye to Hostinger par absolute path try karo:
# DATABASE_URL=file:/home/USERNAME/domains/DOMAIN/nodejs/prisma/prod.db
AUTH_SECRET=PASTE_OPENSSL_OR_CRYPTO_RANDOM_STRING_HERE_MIN_32_CHARS
PUBLIC_SITE_URL=https://ramlahinternational.com
ADMIN_SEED_EMAIL=admin@ramlahinternational.com
ADMIN_SEED_PASSWORD=Ramlah!Deploy2026-FirstLoginChangeMe
ADMIN_SEED_NAME=Ramlah Admin
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=Ramlah International <noreply@ramlahinternational.com>
NOTIFY_EMAIL=hello@ramlahinternational.com
